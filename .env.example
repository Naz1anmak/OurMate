# ─── Telegram ──────────────────────────────────────────────
BOT_TOKEN=                # @BotFather → /newbot → токен
OWNER_CHAT_ID=            # ваш Telegram user_id (узнать через @userinfobot)
CHAT_ID=                  # ID основной группы (отрицательное число для супергрупп)

# Опциональный SOCKS5-прокси к Telegram Bot API
TELEGRAM_PROXY_URL=       # пример: login:password@host:port или host:port
TELEGRAM_PROXY_ENABLED=false

# ─── LLM ───────────────────────────────────────────────────
API_URL=https://api.deepseek.com/v1/chat/completions
MODEL=deepseek-v4-flash
LLM_API_KEY=              # ключ от провайдера LLM

# ─── Дни рождения ──────────────────────────────────────────
BIRTHDAYS_FILE=data/birthdays.json
LAST_BIRTHDAY_GREETING_FILE=data/cache/last_birthday_greeting.txt
SEND_HOUR=10
SEND_MINUTE=0

# ─── Расписание ────────────────────────────────────────────
# Каталог с расписанием. Группы определяются по подпапкам data/<CODE>/, где
# <CODE> — короткий идентификатор группы (он же — суффикс в RUZ_GROUP_<CODE>, см. ниже).
# При непустом RUZ_GROUP_IDS учитываются только подпапки из whitelist.
SCHEDULE_GROUPS_DIR=data
# Префикс отображаемого имени группы; подклеивается к <CODE> при выводе.
# Пример: SCHEDULE_GROUP_NAME_PREFIX="prefix/" + папка data/A/ → отображение "prefix/A".
# Оставьте пустым, чтобы показывать только <CODE>.
SCHEDULE_GROUP_NAME_PREFIX=
SCHEDULE_CACHE_FILE=data/cache/schedule_cache.json
SCHEDULE_SEND_HOUR=8
SCHEDULE_SEND_MINUTE=0
SCHEDULE_BROADCAST_ENABLED=false

# ─── Автообновление расписания (JSON-API) ──────────────────
# Включает фоновое обновление расписания + lazy-refresh по команде «пары».
SCHEDULE_AUTO_UPDATE_ENABLED=true
# Базовый URL JSON-API расписания — со схемой, без завершающего /.
# Пустое значение = автообновление выключено де-факто.
# Пример: RUZ_BASE_URL=https://<домен-портала-расписания>
RUZ_BASE_URL=
# ID факультета (нужен только для гиперссылки в сообщениях об ошибке).
RUZ_FACULTY_ID=125
# Сколько недель вперёд тянуть (текущая + N).
RUZ_WEEKS_AHEAD=3
# Таймаут одного HTTP-запроса к API расписания, секунды.
RUZ_HTTP_TIMEOUT=15
# TTL «свежести» snapshot'а для lazy-refresh по команде, минуты.
RUZ_LAZY_TTL_MIN=60
# Маппинг подпапок data/<CODE>/ на внутренний group_id из API расписания — по одной переменной на группу.
#
# Внимание: <CODE> и <ID> — это РАЗНЫЕ идентификаторы.
#   <CODE> (слева) — короткое имя группы, оно же имя подпапки data/<CODE>/.
#   <ID>   (справа) — внутренний group_id из системы расписания, число в URL вида
#                     https://<RUZ_BASE_URL>/faculty/<RUZ_FACULTY_ID>/groups/<ID>?date=YYYY-M-D
#                     Открой свою группу на сайте расписания — это число между `/groups/` и `?date=`.
#
# Пример (две группы с короткими именами A и B):
# RUZ_GROUP_A=111111
# RUZ_GROUP_B=222222

# Закреплённое сообщение с расписанием в группе
PINNED_SCHEDULE_ENABLED=false
PINNED_SCHEDULE_UPDATE_HOUR=0
PINNED_SCHEDULE_UPDATE_MINUTE=0
# Сколько ближайших учебных дней (дат с парами) показывать в закрепе.
PINNED_SCHEDULE_DAYS_AHEAD=7
PINNED_SCHEDULE_MESSAGE_FILE=data/cache/pinned_schedule_id.txt

# ─── Промпты LLM ───────────────────────────────────────────
# Используйте кавычки и экранированные \n при необходимости.
PROMPT_TEMPLATE_CHAT=
PROMPT_TEMPLATE_BIRTHDAY_ACTIVE=
PROMPT_TEMPLATE_BIRTHDAY_FORMER=

# ─── Прочее ────────────────────────────────────────────────
TIMEZONE=Europe/Moscow
ENV=dev                   # dev | prod
LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR
