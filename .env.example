# ─── Telegram ──────────────────────────────────────────────
BOT_TOKEN=                # @BotFather → /newbot → токен
OWNER_CHAT_ID=            # ваш Telegram user_id (узнать через @userinfobot)
CHAT_ID=                  # ID основной группы (отрицательное число для супергрупп)

# Опциональный SOCKS5-прокси к Telegram Bot API
TELEGRAM_PROXY_URL=       # пример: login:password@host:port или host:port
TELEGRAM_PROXY_ENABLED=false

# ─── LLM ───────────────────────────────────────────────────
API_URL=https://api.deepseek.com/v1/chat/completions
MODEL=deepseek-reasoner
LLM_API_KEY=              # ключ от провайдера LLM

# ─── Дни рождения ──────────────────────────────────────────
BIRTHDAYS_FILE=data/birthdays.json
LAST_BIRTHDAY_GREETING_FILE=data/cache/last_birthday_greeting.txt
SEND_HOUR=10
SEND_MINUTE=0

# ─── Расписание ────────────────────────────────────────────
# Каталог с расписанием. Подпапки = multi-group режим (data/40001, data/40002),
# иначе single-group по SCHEDULE_FILES_PATTERN.
SCHEDULE_GROUPS_DIR=data
# Префикс отображаемого имени группы. Пример: "з51904/" + папка "40001" → "з51904/40001".
SCHEDULE_GROUP_NAME_PREFIX=
# Single-group fallback (используется, если в SCHEDULE_GROUPS_DIR нет подпапок).
SCHEDULE_FILES_PATTERN=data/calendar*.ics
SCHEDULE_CACHE_FILE=data/cache/schedule_cache.json
SCHEDULE_SEND_HOUR=8
SCHEDULE_SEND_MINUTE=0
SCHEDULE_BROADCAST_ENABLED=false

# Закреплённое сообщение с расписанием в группе
PINNED_SCHEDULE_ENABLED=false
PINNED_SCHEDULE_UPDATE_HOUR=0
PINNED_SCHEDULE_UPDATE_MINUTE=0
# Сколько ближайших учебных дней (дат с парами) показывать в закрепе.
PINNED_SCHEDULE_DAYS_AHEAD=7
PINNED_SCHEDULE_MESSAGE_FILE=data/cache/pinned_schedule_id.txt

# ─── Промпты LLM ───────────────────────────────────────────
# Используйте кавычки и экранированные \n при необходимости.
PROMPT_TEMPLATE_CHAT=
PROMPT_TEMPLATE_BIRTHDAY_ACTIVE=
PROMPT_TEMPLATE_BIRTHDAY_FORMER=

# ─── Прочее ────────────────────────────────────────────────
TIMEZONE=Europe/Moscow
ENV=dev                   # dev | prod
LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR
